rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isAuth() {
      return request.auth != null;
    }

    function isOwnAvatar(fileName) {
      return isAuth()
        && fileName.matches(request.auth.uid + "\\.(jpg|jpeg|png|webp)");
    }

    match /avatars/{fileName} {
      allow read: if isAuth();
      allow write: if isOwnAvatar(fileName)
        && request.resource.size < 2 * 1024 * 1024
        && request.resource.contentType.matches("image/(jpeg|png|webp)");
    }

    match /users/{userId}/{fileName} {
      allow read: if isAuth() && request.auth.uid == userId;
      allow write: if isAuth()
        && request.auth.uid == userId
        && request.resource.size < 2 * 1024 * 1024
        && request.resource.contentType.matches("image/(jpeg|png|webp)");
    }

    // ── SUPPORT CHAT IMAGES ──────────────────────────
    match /supportChats/{userId}/{fileName} {
      allow read: if isAuth();
      // Owner can upload images and documents (max 16 MB)
      allow write: if isAuth()
        && request.auth.uid == userId
        && request.resource.size < 16 * 1024 * 1024;
      // Admins can upload any file for any chat (fileName starts with "admin_")
      allow write: if isAuth()
        && fileName.matches("admin_.*")
        && request.resource.size < 16 * 1024 * 1024;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
