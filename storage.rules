rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isAuth() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuth()
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    function isOwnAvatar(fileName) {
      return isAuth()
        && fileName.matches(request.auth.uid + "\\.(jpg|jpeg|png|webp)");
    }

    match /avatars/{fileName} {
      allow read: if isAuth();
      allow write: if isOwnAvatar(fileName)
        && request.resource.size < 2 * 1024 * 1024
        && request.resource.contentType.matches("image/(jpeg|png|webp)");
    }

    match /users/{userId}/{fileName} {
      allow read: if isAuth() && request.auth.uid == userId;
      allow write: if isAuth()
        && request.auth.uid == userId
        && request.resource.size < 2 * 1024 * 1024
        && request.resource.contentType.matches("image/(jpeg|png|webp)");
    }

    // ── SUPPORT CHAT FILES ───────────────────────────
    match /supportChats/{userId}/{fileName} {
      allow read: if isAuth();
      // Owner can upload files (max 16 MB)
      allow write: if isAuth()
        && request.auth.uid == userId
        && request.resource.size < 16 * 1024 * 1024;
      // Admins can upload to any chat (verified via Firestore isAdmin flag)
      allow write: if isAdmin()
        && request.resource.size < 16 * 1024 * 1024;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
