rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if caller is admin
    function isAdmin() {
      return request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // ─── USERS ───────────────────────────────────────────────
    // Read any user (needed for referral code lookup).
    // Write only own document.
    match /users/{userId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ─── POINTS HISTORY ──────────────────────────────────────
    // Own records only.
    match /pointsHistory/{docId} {
      allow read:   if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }

    // ─── NOTIFICATIONS ───────────────────────────────────────
    // Own notifications only.
    match /notifications/{docId} {
      allow read:   if request.auth != null && resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // ─── RAFFLES ─────────────────────────────────────────────
    // Any authenticated user can read.
    // Write restricted to admins (isAdmin: true in users doc).
    // NOTE: sorteos.js currently increments `participants` from the client.
    // That write will be blocked by this rule until confirmParticipation()
    // is moved to a Cloud Function (sorteos Cloud Function — pending task).
    match /raffles/{raffleId} {
      allow read:  if request.auth != null;
      allow write: if isAdmin();
    }

    // ─── RAFFLE PARTICIPANTS ──────────────────────────────────
    // Users can read and create their own participation docs.
    // Users can update their own doc (e.g. requirementsCompleted).
    // No delete allowed from client.
    match /raffleParticipants/{participantId} {
      allow read:   if request.auth != null
                    && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null
                    && resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    // ─── REDEEM REQUESTS ─────────────────────────────────────
    // Users create their own requests (userId must match caller).
    // Users read their own requests.
    // Admins can read all and update status (approve/reject).
    match /redeemRequests/{requestId} {
      allow read:   if request.auth != null
                    && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if false;
    }

    // ─── SHOP (read-only) ─────────────────────────────────────
    match /shopDailyItems/{docId} {
      allow read: if request.auth != null;
    }
    match /shopDaily/{docId} {
      allow read: if request.auth != null;
    }

    // ─── CONTENT (read-only) ──────────────────────────────────
    match /noticias/{docId} {
      allow read: if request.auth != null;
    }
    match /cosmeticos/{docId} {
      allow read: if request.auth != null;
    }
    match /sorteos/{docId} {
      allow read: if request.auth != null;
    }
    match /stats/{docId} {
      allow read: if request.auth != null;
    }

    // ─── TRANSACTIONS (server-side only) ─────────────────────
    match /ayetTransactions/{docId} {
      allow read, write: if false;
    }
    match /adgemTransactions/{docId} {
      allow read, write: if false;
    }
  }
}
