rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if caller is admin
    function isAdmin() {
      return request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function allowedUserCreateFields() {
      return [
        "uid", "username", "displayName", "email", "provider", "photoURL",
        "points", "level", "experience", "nextLevel", "gamesPlayed",
        "achievements", "sorteosParticipados", "createdAt", "lastLogin",
        "pendingReferral", "referralCode", "loginCount", "fcmToken",
        "fcmTokenUpdated", "notificationsEnabled"
      ];
    }

    function allowedUserUpdateFields() {
      return [
        "uid", "username", "displayName", "email", "provider", "photoURL",
        "lastLogin", "loginCount", "pendingReferral", "referralCode",
        "fcmToken", "fcmTokenUpdated", "notificationsEnabled", "updatedAt"
      ];
    }

    function validUserCreate(userId) {
      return isOwner(userId)
        && request.resource.data.keys().hasOnly(allowedUserCreateFields())
        && request.resource.data.uid == userId
        && request.resource.data.points == 175
        && request.resource.data.level == 1
        && request.resource.data.experience == 0
        && request.resource.data.nextLevel == 200
        && !request.resource.data.keys().hasAny(["isAdmin"]);
    }

    function validUserUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(allowedUserUpdateFields());
    }

    // ─── USERS ───────────────────────────────────────────────
    // Read any user (needed for referral code lookup).
    // Users can only create their initial profile and update non-sensitive fields.
    // Points, admin flags, game state and counters are server-side only.
    match /users/{userId} {
      allow read:  if request.auth != null;
      allow create: if validUserCreate(userId);
      allow update: if isOwner(userId) && validUserUpdate();
      allow delete: if false;
    }

    // ─── POINTS HISTORY ──────────────────────────────────────
    // Own records only.
    match /pointsHistory/{docId} {
      allow read:   if request.auth != null && resource.data.userId == request.auth.uid;
      allow create, update, delete: if false;
    }

    // ─── NOTIFICATIONS ───────────────────────────────────────
    // Personal notifications (userId == uid) or global broadcasts (userId == "ALL").
    // Only admins can create notifications (global or personal).
    match /notifications/{docId} {
      allow read:   if request.auth != null
                    && (resource.data.userId == request.auth.uid
                        || resource.data.userId == "ALL");
      allow create: if isAdmin();
      allow update: if request.auth != null && resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // ─── RAFFLES ─────────────────────────────────────────────
    // Any authenticated user can read.
    // Write restricted to admins (isAdmin: true in users doc).
    // NOTE: sorteos.js currently increments `participants` from the client.
    // That write will be blocked by this rule until confirmParticipation()
    // is moved to a Cloud Function (sorteos Cloud Function — pending task).
    match /raffles/{raffleId} {
      allow read:  if request.auth != null;
      allow write: if isAdmin();
    }

    // ─── RAFFLE PARTICIPANTS ──────────────────────────────────
    // Read: any authenticated user can read (needed for own entry queries).
    // Create/update/delete: server-side only via participateInRaffle Cloud Function.
    // NOTE: finishRequirements() in sorteos.js attempts to update
    // requirementsCompleted — it will silently fail until moved to a Cloud Function.
    match /raffleParticipants/{participantId} {
      allow read:             if request.auth != null;
      allow create, update,
            delete:           if false;
    }

    // ─── REDEEM REQUESTS ─────────────────────────────────────
    // Users create their own requests (userId must match caller).
    // Users read their own requests.
    // Admins can read all and update status (approve/reject).
    match /redeemRequests/{requestId} {
      allow read:   if request.auth != null
                    && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if false;
      allow update: if isAdmin();
      allow delete: if false;
    }

    // ─── SHOP (read-only) ─────────────────────────────────────
    match /shopDailyItems/{docId} {
      allow read: if request.auth != null;
    }
    match /shopDaily/{docId} {
      allow read: if request.auth != null;
    }

    // ─── CONTENT (read-only) ──────────────────────────────────
    match /news/{docId} {
      allow read:  if request.auth != null;
      allow write: if isAdmin();
    }
    match /noticias/{docId} {
      allow read: if request.auth != null;
    }
    match /cosmeticos/{docId} {
      allow read: if request.auth != null;
    }
    match /sorteos/{docId} {
      allow read: if request.auth != null;
    }
    match /stats/{docId} {
      allow read: if request.auth != null;
    }

    // ─── GLOBAL NOTIFICATIONS (admin only) ───────────────────
    match /globalNotifications/{docId} {
      allow read, write: if isAdmin();
    }

    // ─── TRANSACTIONS (server-side only) ─────────────────────
    match /ayetTransactions/{docId} {
      allow read, write: if false;
    }
    match /adgemTransactions/{docId} {
      allow read, write: if false;
    }
  }
}
